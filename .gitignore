# OS / editor
.DS_Store
*.log

# secrets — never commit (nested .gitignores also cover these)
.env
.env.*
**/.env
**/.env.*

# dependencies / build (also covered by web/.gitignore)
node_modules/
**/node_modules/
.next/
out/
*.tsbuildinfo

# python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# large test media, experiments & model caches
# (the curated translation/samples/ clips are committed explicitly via the negation below)
tests/
*.mp4
Untitled
!translation/samples/*.mp4
